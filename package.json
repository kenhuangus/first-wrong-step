{
  "name": "first-wrong-step",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.18.0",
    "npm": "11.16.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "vitest run",
    "test:list": "vitest list",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "build:client": "vite build",
    "build:manifest": "node scripts/generate-static-manifest.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run typecheck && npm run build:client && npm run build:manifest && npm run build:server",
    "start": "node build/server/static-host.js",
    "smoke:production": "node scripts/smoke-production.mjs",
    "ci": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e:list && npm run smoke:production"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
